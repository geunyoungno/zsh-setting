echo "\n--------------------"
echo "Fonts update"
if [ -d "$ZSHR/nerd-fonts" ]
then
    echo "Nerd Fonts is not installed.\n"
    while true; do
        read -p "Do you Install Nerd Fonts? [Y/N]" ans
        case $ans in
            [Yy]*)
                source $ZSHR/install_font.sh
                return
                ;;
            [Nn]*)
                echo "Don't Install Fonts."
                return
        esac
        echo "Please answer again."
    done
fi

cd $ZSHR/nerd-fonts && git pull && ./install.sh
