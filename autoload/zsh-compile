# @docwhat
echo "-------"
echo "Zcompile ZSH Files"
# Remove old compile files that may be stale
rm -f ~/.*.zwc(N.)
find \
    ${ZSHR}(N/) \
    -name '*.zwc' \
    -print0 \
    | xargs -0 rm

# My stuff
_zcompile-custom ~/.zshrc ~/.zshenv ~/.zlogin
_zcompile-custom ${ZSHR}/*.{zshrc,zshenv,zlogin}(N^/)
_zcompile-custom ${ZSHR}/autoload/*(N^/)
_zcompile-custom ${ZSHR}/lib/*(N^/)
